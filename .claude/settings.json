{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/blindspot-code-review-on-commit.py",
            "if": "Bash(git commit*)",
            "timeout": 130,
            "statusMessage": "Running pre-commit code review..."
          }
        ]
      }
    ]
  }
}
