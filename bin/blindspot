#!/usr/bin/env bash
# Permanent CLI wrapper. Bypasses pip's editable .pth — works regardless
# of whether the macOS com.apple.provenance xattr has corrupted the
# install. Always finds the package via PYTHONPATH=<repo>/src.
#
# Usage: ./bin/blindspot ask "..."
set -e
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
REPO_ROOT="$( cd "${SCRIPT_DIR}/.." && pwd )"

# Load project-local secrets (VOYAGE_API_KEY, REDDIT_*) if present. Lives
# outside the repo so it isn't checked in, and is reachable from any
# worktree or scheduled-task environment that doesn't inherit the user's
# interactive shell rc.
if [ -f "${HOME}/.blindspot/.env" ]; then
  set -a
  . "${HOME}/.blindspot/.env"
  set +a
fi

export PYTHONPATH="${REPO_ROOT}/src${PYTHONPATH:+:${PYTHONPATH}}"
exec "${REPO_ROOT}/.venv/bin/python" -m blindspot.cli "$@"
